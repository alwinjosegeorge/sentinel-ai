# Project Sentinel Environment Variable Template
# Copy this file to '.env' and fill in your custom API keys.

# Mapbox Access Token (for vector map styles and route direction geometry)
VITE_MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_TOKEN

# Gemini AI API Key (for auto-filled incident classification and resident assistance)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# OpenWeather API Key (for real-time weather and flood sensors)
VITE_OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
